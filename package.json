{
  "name": "conference-app",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "clean": "rm -rf apps/web/.next apps/attendee/.next apps/meetings/.next apps/sponsor/.next",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "predev": "npm run clean",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:attendee": "npm run clean && turbo dev --filter=attendee",
    "dev:web": "npm run clean && turbo dev --filter=web",
    "dev:meetings": "npm run clean && turbo dev --filter=meetings",
    "dev:sponsor": "npm run clean && turbo dev --filter=sponsor",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @conference/db db:generate",
    "db:migrate": "pnpm --filter @conference/db db:migrate",
    "db:push": "pnpm --filter @conference/db db:push",
    "db:seed": "pnpm --filter @conference/db db:seed",
    "db:studio": "pnpm --filter @conference/db db:studio",
    "test:design": "node scripts/test-design-system.mjs",
    "test:buttons": "node scripts/test-button-style.mjs",
    "test:overview-bars": "node scripts/test-overview-health-bars.mjs",
    "test:health-progress": "node scripts/test-health-progress.mjs",
    "bench:data": "node scripts/bench-data-layer.mjs",
    "test:browse": "node scripts/test-browse-taxonomy.mjs && node scripts/test-browse-guarantee.mjs",
    "test:access": "node scripts/test-access-counts.mjs",
    "test:roles": "node scripts/test-role-permissions.mjs",
    "test:roles:api": "node scripts/test-role-permissions-api.mjs",
    "test:sponsor-team": "node scripts/test-sponsor-team.mjs",
    "e2e:sponsor-team": "node scripts/e2e-sponsor-team.mjs",
    "test:meetings-team": "node scripts/test-meetings-team.mjs",
    "e2e:meetings-team": "node scripts/e2e-meetings-team.mjs",
    "smoketest:browse": "node scripts/smoketest-browse-api.mjs",
    "test:scheduled": "node scripts/test-scheduled-messages.mjs",
    "test:scheduled:api": "node scripts/test-scheduled-messages-api.mjs",
    "test:feed": "node scripts/test-home-feed.mjs",
    "test:feed:api": "node scripts/test-home-feed-api.mjs",
    "e2e:feed": "node scripts/e2e-home-feed.mjs",
    "db:migrate-scheduled": "node scripts/migrate-scheduled-messages.mjs",
    "db:migrate-feed": "node scripts/migrate-feed-social.mjs",
    "seed:feed-posts": "node scripts/seed-feed-posts.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "prisma": "^5.22.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
