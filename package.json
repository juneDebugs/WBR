{
  "name": "conference-app",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:attendee": "turbo dev --filter=attendee",
    "dev:web": "turbo dev --filter=web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @conference/db db:generate",
    "db:migrate": "pnpm --filter @conference/db db:migrate",
    "db:push": "pnpm --filter @conference/db db:push",
    "db:seed": "pnpm --filter @conference/db db:seed",
    "db:studio": "pnpm --filter @conference/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma"]
  }
}
