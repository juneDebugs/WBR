generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Adapter Tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  company       String?
  jobTitle      String?
  role          String    @default("ATTENDEE") // ATTENDEE | SPEAKER | ORGANIZER
  password      String?
  pushToken     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  companySize      String?   // STARTUP | SMB | MIDMARKET | ENTERPRISE
  annualRevenue    String?   // <1M | 1M-10M | 10M-50M | 50M-250M | 250M+
  solutionsOffering String?  // JSON string array
  solutionsSeeking  String?  // JSON string array
  website          String?
  sponsorId        String?   // link to Sponsor company

  accounts          Account[]
  sessions          Session[]
  meetingsAsA       Meeting[]       @relation("MeetingAttendeeA")
  meetingsAsB       Meeting[]       @relation("MeetingAttendeeB")
  organizedMeetings Meeting[]       @relation("MeetingOrganizer")
  blackoutTimes     BlackoutTime[]
  speakerProfile    Speaker?
  chatMemberships   ChatMember[]
  messages          Message[]
  following         Follow[]          @relation("UserFollowing")
  followers         Follow[]          @relation("UserFollowers")
  posts             Post[]
  postLikes         PostLike[]
  sponsorMeetings   SponsorMeeting[]
  sessionBookmarks  SessionBookmark[]
  requestsMade     MeetingRequest[] @relation("RequestsMade")
  requestsReceived MeetingRequest[] @relation("RequestsReceived")
  sponsor          Sponsor?         @relation("SponsorUser", fields: [sponsorId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([sponsorId])
  @@index([createdAt])
}

// ─── Conference ──────────────────────────────────────────────────────────────

model Conference {
  id            String   @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  venue         String?
  venueLat      Float?
  venueLon      Float?
  venueTimezone String?
  logoUrl       String?
  heroImageUrl  String?
  wifiName      String?
  wifiPassword  String?
  loginTitle    String?
  loginSubtitle String?
  loginButtonText String?
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([active])

  speakers     Speaker[]
  confSessions ConfSession[]
  timeBlocks   TimeBlock[]
  meetings     Meeting[]
  sponsors     Sponsor[]
}

// ─── Speakers ────────────────────────────────────────────────────────────────

model Speaker {
  id            String   @id @default(cuid())
  conferenceId  String
  userId        String?  @unique
  name          String
  bio           String?
  role          String?
  lookingFor    String?
  photoUrl      String?
  company       String?
  jobTitle      String?
  twitterHandle String?
  linkedinUrl   String?
  createdAt     DateTime @default(now())

  conference   Conference  @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  confSessions ConfSession[]
  conflicts    ConflictLog[]

  @@index([conferenceId])
}

// ─── Conference Sessions ──────────────────────────────────────────────────────
// Named ConfSession to avoid collision with NextAuth Session model

model ConfSession {
  id           String   @id @default(cuid())
  conferenceId String
  title        String
  description  String?
  speakerId    String?
  room         String?
  startsAt     DateTime
  endsAt       DateTime
  track        String?
  type         String   @default("TALK") // TALK | WORKSHOP | BREAK | KEYNOTE | PANEL
  createdAt    DateTime @default(now())

  conference   Conference       @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  speaker      Speaker?         @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  bookmarks    SessionBookmark[]
  conflictsAsA ConflictLog[]    @relation("ConflictSessionA")
  conflictsAsB ConflictLog[]    @relation("ConflictSessionB")

  @@index([conferenceId, startsAt])
  @@index([speakerId])
}

// ─── Time Blocks ─────────────────────────────────────────────────────────────

model TimeBlock {
  id           String   @id @default(cuid())
  conferenceId String
  startsAt     DateTime
  endsAt       DateTime
  location     String?
  capacity     Int      @default(1)
  createdAt    DateTime @default(now())

  conference      Conference       @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  meetings        Meeting[]
  sponsorMeetings SponsorMeeting[]
  meetingRequests MeetingRequest[]

  @@index([conferenceId, startsAt])
}

// ─── Blackout Times ──────────────────────────────────────────────────────────

model BlackoutTime {
  id        String   @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
}

// ─── Meetings ────────────────────────────────────────────────────────────────

model Meeting {
  id           String   @id @default(cuid())
  conferenceId String
  timeBlockId  String
  organizerId  String
  attendeeAId  String
  attendeeBId  String
  status       String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conference Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  timeBlock  TimeBlock  @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)
  organizer  User       @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  attendeeA  User       @relation("MeetingAttendeeA", fields: [attendeeAId], references: [id])
  attendeeB  User       @relation("MeetingAttendeeB", fields: [attendeeBId], references: [id])

  @@index([attendeeAId])
  @@index([attendeeBId])
  @@index([timeBlockId])
  @@index([conferenceId])
  @@index([organizerId])
  @@index([status])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatRoom {
  id        String   @id @default(cuid())
  name      String?  // null for direct messages
  type      String   @default("CHANNEL") // CHANNEL | DIRECT
  createdAt DateTime @default(now())

  members  ChatMember[]
  messages Message[]
}

model ChatMember {
  id         String    @id @default(cuid())
  roomId     String
  userId     String
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

// ─── Sponsors ────────────────────────────────────────────────────────────────

model Sponsor {
  id           String   @id @default(cuid())
  conferenceId String
  name         String
  tagline      String?
  logoUrl      String?
  heroImageUrl String?
  website      String?
  tier         String   @default("GOLD") // PLATINUM | GOLD | SILVER | BRONZE
  contactName  String?
  contactEmail String?
  contactPhone String?
  description  String?
  companySize      String?
  annualRevenue    String?
  founded          String?
  headquarters     String?
  boothNumber      String?
  socialLinkedIn   String?
  socialTwitter    String?
  solutionsOffering String?
  solutionsSeeking  String?
  targetIndustries  String?  // JSON array of industries they want to meet
  targetCompanySizes String? // JSON array
  targetRevenues    String?  // JSON array
  createdAt    DateTime @default(now())

  conference   Conference       @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  meetings     SponsorMeeting[]
  meetingRequests  MeetingRequest[]
  users            User[]           @relation("SponsorUser")
  submissionForms  SubmissionForm[]

  @@index([conferenceId])
}

model SessionBookmark {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ConfSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
}

model SponsorMeeting {
  id          String   @id @default(cuid())
  sponsorId   String
  userId      String   // The attendee/speaker being met
  repId       String?  // The sponsor team rep handling this meeting
  timeBlockId String
  status      String   @default("CONFIRMED") // CONFIRMED | CANCELLED
  notes       String?
  createdAt   DateTime @default(now())

  sponsor     Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeBlock   TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
  @@index([userId])
  @@index([repId])
  @@index([status])
  @@index([sponsorId, status])
  @@index([timeBlockId])
}

model MeetingRequest {
  id              String   @id @default(cuid())
  requesterId     String
  targetUserId    String?
  targetSponsorId String?
  message         String?
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | CONFIRMED
  timeBlockId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requester     User       @relation("RequestsMade", fields: [requesterId], references: [id], onDelete: Cascade)
  targetUser    User?      @relation("RequestsReceived", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetSponsor Sponsor?   @relation(fields: [targetSponsorId], references: [id], onDelete: SetNull)
  timeBlock     TimeBlock? @relation(fields: [timeBlockId], references: [id], onDelete: SetNull)

  @@index([requesterId])
  @@index([targetUserId])
  @@index([targetSponsorId])
  @@index([status])
  @@index([status, timeBlockId])
  @@index([timeBlockId])
  @@index([requesterId, status])
  @@index([createdAt])
}

// ─── Follow ───────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ─── Feed Posts ───────────────────────────────────────────────────────────────

model Post {
  id        String     @id @default(cuid())
  authorId  String
  content   String
  imageUrl  String?
  createdAt DateTime   @default(now())

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]

  @@index([authorId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── Conflict Log ─────────────────────────────────────────────────────────────

model ConflictLog {
  id         String   @id @default(cuid())
  speakerId  String
  sessionAId String
  sessionBId String
  detectedAt DateTime @default(now())
  resolved   Boolean  @default(false)

  speaker  Speaker     @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  sessionA ConfSession @relation("ConflictSessionA", fields: [sessionAId], references: [id], onDelete: Cascade)
  sessionB ConfSession @relation("ConflictSessionB", fields: [sessionBId], references: [id], onDelete: Cascade)

  @@unique([sessionAId, sessionBId])
  @@index([speakerId])
  @@index([resolved])
}

// ─── Submission Forms ─────────────────────────────────────────────────────────

model SubmissionForm {
  id          String    @id @default(cuid())
  sponsorId   String
  title       String
  type        String    @default("ABSTRACT") // ABSTRACT | FULL_PAPER | SPEAKER_PROPOSAL | PANEL | SYMPOSIUM | CUSTOM
  description String?
  fields      String    @default("[]") // JSON array of field definitions
  isOpen      Boolean   @default(true)
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sponsor     Sponsor          @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([sponsorId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  name      String?
  email     String?
  data      String   @default("{}") // JSON object of field values
  status    String   @default("PENDING") // PENDING | REVIEWED | ACCEPTED | REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form SubmissionForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([status])
}

// ─── Email Log ────────────────────────────────────────────────────────────────

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  body      String
  status    String   @default("SENT") // SENT | FAILED
  sponsorId String?
  sentAt    DateTime @default(now())

  @@index([sentAt])
  @@index([sponsorId])
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id           String    @id @default(cuid())
  provider     String    @unique // GMAIL | GOOGLE_CALENDAR | OUTLOOK | OUTLOOK_CALENDAR | SLACK | NOTION | ZAPIER | HUBSPOT
  status       String    @default("DISCONNECTED") // CONNECTED | DISCONNECTED | ERROR
  accountLabel String?   // e.g. "june@wbr.com"
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  metadata     String?   // JSON blob for provider-specific data
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
