# Database
DATABASE_URL="file:../../packages/db/prisma/dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"  # attendee app
# NEXTAUTH_URL="http://localhost:3000"  # admin app

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin app only: comma-separated list of allowed organizer emails
ADMIN_EMAILS="organizer@example.com,co-organizer@example.com"

# OpenAI (for AI features)
OPENAI_API_KEY="sk-..."

# Conference ID (used as fallback if no active conference in DB)
CONFERENCE_ID="conf-2025"

# Sponsor portal URL (used in reminder emails)
SPONSOR_PORTAL_URL="https://sponsors.yourconference.com"
